      <lstol>0.0</lstol>
      <min_residual>1e-10</min_residual>
      <linear_solver type="pardiso" />
      <qn_method type="BFGS" />
      <max_refs>10</max_refs>
      <max_ups>0</max_ups>
      <symmetric_stiffness>0</symmetric_stiffness>
    </solver>
  </Control>
