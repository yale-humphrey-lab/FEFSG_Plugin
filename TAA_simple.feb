<?xml version='1.0' encoding='utf-8'?>
<febio_spec version="3.0">
  <Module type="solid" />
  <Control>
    <analysis>STATIC</analysis>
    <time_steps>2</time_steps>
    <step_size>1.0</step_size>
    <solver>
      <diverge_reform>1</diverge_reform>
      <reform_each_time_step>1</reform_each_time_step>
      <dtol>0</dtol>
